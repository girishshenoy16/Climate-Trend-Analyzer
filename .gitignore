# ==========================================
# Python Cache / Compiled Files
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# ==========================================
# Virtual Environments
# ==========================================
venv/
.venv/
env/
ENV/

# ==========================================
# IDE / Editors
# ==========================================
.vscode/
.idea/
*.iml

# ==========================================
# OS Files
# ==========================================
.DS_Store
Thumbs.db
desktop.ini

# ==========================================
# Pytest / Coverage / Cache
# ==========================================
.pytest_cache/
.coverage
htmlcov/
.cache/
.tox/

# ==========================================
# Jupyter
# ==========================================
.ipynb_checkpoints/

# ==========================================
# Logs
# ==========================================
*.log

# ==========================================
# Build / Packaging
# ==========================================
build/
dist/
*.egg-info/
.eggs/

# ==========================================
# Environment Variables / Secrets
# ==========================================
.env
.env.*

# ==========================================
# Database
# ==========================================
*.db
*.sqlite3

# ==========================================
# Temporary Files
# ==========================================
*.tmp
*.bak
*.swp
*.swo

# ==========================================
# Model Artifacts
# Keep tracked if showcasing final model
# Uncomment below to ignore models
# ==========================================
models/*.pkl

# ==========================================
# Outputs
# Keep charts/reports if showcasing
# Uncomment below to ignore generated outputs
# ==========================================
outputs/

# ==========================================
# Screenshots
# Keep screenshots for README showcase
# Uncomment below to ignore
# ==========================================
# screenshots/*

# ==========================================
# Flask Session Files
# ==========================================
flask_session/

# ==========================================
# Data Files
# ==========================================
data/*

# ==========================================
# Misc Hidden Files
# ==========================================
*.pid
*.seed

